---
// Despedida.astro
---

<section class="py-12 px-4 relative overflow-hidden">
  <!-- Fondo sutil -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-[#fffaf5]/30 via-transparent to-[#fff5f5]/30 z-0"
  >
  </div>

  <div class="max-w-5xl mx-auto relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <!-- 🌸 FLORES SUPERIORES -->
      <div class="flex justify-center mb-8" id="flores-arriba-despedida">
        <img
          src="/imagenes/FlorArribaSeparador.webp"
          alt="Flores decorativas"
          class="w-48 md:w-56 lg:w-64 h-auto object-contain"
        />
      </div>

      <!-- CARD CONTENEDOR DEL MENSAJE -->
      <div
        class="relative backdrop-blur-sm bg-white/70 rounded-3xl border border-[#a27735]/20 shadow-lg p-8 md:p-10 lg:p-12"
        id="card-despedida"
      >
        <!-- Brillo superior -->
        <div
          class="absolute top-0 left-0 right-0 h-1/3 bg-gradient-to-b from-white/30 to-transparent rounded-t-3xl pointer-events-none"
        >
        </div>

        <!-- Esquinas decorativas -->
        <div
          class="absolute top-2 left-2 w-12 h-12 border-t-2 border-l-2 border-[#a27735]/30"
        >
        </div>
        <div
          class="absolute top-2 right-2 w-12 h-12 border-t-2 border-r-2 border-[#a27735]/30"
        >
        </div>
        <div
          class="absolute bottom-2 left-2 w-12 h-12 border-b-2 border-l-2 border-[#a27735]/30"
        >
        </div>
        <div
          class="absolute bottom-2 right-2 w-12 h-12 border-b-2 border-r-2 border-[#a27735]/30"
        >
        </div>

        <div class="relative z-10">
          <!-- MENSAJE PRINCIPAL -->
          <div id="mensaje-despedida">
            <p
              class="parrafo-animado font-charm text-xl md:text-xl lg:text-2xl text-[#7fa17c] leading-relaxed mb-6"
            >
              Con la bendición de Dios y el amor de toda mi familia,
              <span class="text-[#7fa17c]">me siento muy feliz</span>
              de llegar a este momento tan especial de mi vida.
            </p>

            <p
              class="parrafo-animado font-charm text-xl md:text-xl lg:text-2xl text-[#7fa17c] leading-relaxed mb-6"
            >
              Ahora empieza un camino lleno de
              <span class="text-[#7fa17c]">sueños e ilusiones</span>
              que, con mucha fe, humildad y esperanza, deseo cumplir.
            </p>

            <p
              class="parrafo-animado font-charm text-xl md:text-xl lg:text-2xl text-[#7fa17c] leading-relaxed mb-6"
            >
              Quisiera, con inmensa alegría,
              <span class="text-[#7fa17c]">compartir este comienzo</span>
              de esta bella etapa junto a todos ustedes.
            </p>

            <!-- Línea decorativa -->
            <div
              class="flex items-center justify-center gap-3 my-4"
              id="linea-decorativa"
            >
              <div
                class="w-16 h-[1px] bg-gradient-to-r from-transparent to-[#a27735]"
              >
              </div>
              <svg
                class="w-6 h-6 text-[#a27735]"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                ></path>
              </svg>
              <div
                class="w-16 h-[1px] bg-gradient-to-l from-transparent to-[#7fa17c]"
              >
              </div>
            </div>
          </div>

          <!-- SECCIÓN CONFIRMAR ASISTENCIA -->
          <div id="seccion-confirmar" class="mt-2">
            <!-- Texto de invitación a confirmar -->
            <p
              class="font-charm text-xl md:text-xl text-[#7fa17c] leading-relaxed mb-2"
              id="texto-confirmar"
            >
              Tu presencia es muy importante para mí.
              <br />
              Por favor, <span class="text-[#7fa17c]"
                >confirma tu asistencia</span
              > para compartir juntos este día tan especial.
            </p>

            <!-- BOTÓN CONFIRMAR ASISTENCIA -->
            <div class="flex justify-center pt-4" id="boton-confirmar">
              <a
                href="https://wa.me/59163450678?text=Me%20complace%20confirmar%20mi%20asistencia%20para%20los%2015%20a%C3%B1os%20de%20Eliane.%20Nos%20vemos%20el%20s%C3%A1bado%2023%20de%20mayo%2C%20estar%C3%A9%20sin%20falta"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Confirmar asistencia por WhatsApp"
                title="Confirmar asistencia por WhatsApp"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-full font-charm text-white text-lg md:text-xl font-bold tracking-wide transition-transform duration-300 hover:scale-105 shadow-md"
                style="background-color: #7fa17c;"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 2.138.564 4.14 1.541 5.875L.057 23.428a.5.5 0 00.609.61l5.627-1.476A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.66-.523-5.176-1.432l-.372-.22-3.862 1.013 1.034-3.772-.242-.386A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
                </svg>
                Confirmar asistencia
              </a>
            </div>

            <!-- MENSAJE FINAL -->
            <p
              class="font-charm pt-4 text-2xl md:text-3xl lg:text-4xl text-[#7fa17c] mb-4"
              id="mensaje-final"
            >
              ¡Los espero con mucho cariño!
            </p>
          </div>
        </div>

        <!-- Resplandor del card -->
        <div
          class="absolute -inset-1 bg-gradient-to-br from-[#a27735]/5 via-transparent to-[#c9a55e]/5 rounded-3xl blur-xl -z-10"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      console.log("💌 Iniciando sección de despedida...");

      // 🎯 ESTADO INICIAL
      gsap.set("#flores-arriba-despedida", { opacity: 0, y: -30, scale: 0.8 });
      gsap.set("#card-despedida", { opacity: 0, y: 40, scale: 0.95 });
      gsap.set(".parrafo-animado", { opacity: 0, y: 30, filter: "blur(5px)" });
      gsap.set("#linea-decorativa", { opacity: 0, scale: 0.5 });
      gsap.set("#texto-confirmar", { opacity: 0, y: 20 });
      gsap.set("#boton-confirmar", { opacity: 0, scale: 0.8, y: 20 });
      gsap.set("#mensaje-final", { opacity: 0, scale: 0.9, y: 20 });

      // ✨ ANIMACIÓN ELEGANTE CON TEXTOS
      ScrollTrigger.create({
        trigger: "#flores-arriba-despedida",
        start: "top 85%",
        end: "top 20%",
        onEnter: () => {
          const tl = gsap.timeline();

          // 1. Flores superiores
          tl.to("#flores-arriba-despedida", {
            opacity: 0.8,
            y: 0,
            scale: 1,
            duration: 0.8,
            ease: "back.out(1.5)",
          })

            // 2. Card aparece
            .to(
              "#card-despedida",
              {
                opacity: 1,
                y: 0,
                scale: 1,
                duration: 0.9,
                ease: "power3.out",
              },
              "-=0.5",
            )

            // 3. Párrafos aparecen con efecto blur
            .to(
              ".parrafo-animado",
              {
                opacity: 1,
                y: 0,
                filter: "blur(0px)",
                duration: 0.8,
                stagger: 0.2,
                ease: "power2.out",
              },
              "-=0.4",
            )

            // 4. Línea decorativa y corazón
            .to(
              "#linea-decorativa",
              {
                opacity: 1,
                scale: 1,
                duration: 0.6,
                ease: "back.out(1.5)",
              },
              "-=0.3",
            )

            // 5. Texto de confirmación
            .to(
              "#texto-confirmar",
              {
                opacity: 1,
                y: 0,
                duration: 0.7,
                ease: "power2.out",
              },
              "-=0.2",
            )

            // 6. Botón aparece
            .to(
              "#boton-confirmar",
              {
                opacity: 1,
                scale: 1,
                y: 0,
                duration: 0.7,
                ease: "back.out(1.5)",
              },
              "-=0.3",
            )

            // 7. Mensaje final
            .to(
              "#mensaje-final",
              {
                opacity: 1,
                scale: 1,
                y: 0,
                duration: 0.8,
                ease: "elastic.out(1, 0.5)",
              },
              "-=0.2",
            );

          // 🌸 ANIMACIONES CONTINUAS
          // Corazón latiendo
          gsap.to("#linea-decorativa svg", {
            scale: 1.2,
            duration: 1.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 0.5,
          });

          // Botón pulsando
          gsap.to("#boton-confirmar img", {
            scale: 1.05,
            y: -3,
            duration: 2,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 0.8,
          });

          // Mensaje final brillando
          gsap.to("#mensaje-final", {
            textShadow: "0 0 15px rgba(162, 119, 53, 0.4)",
            duration: 2,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1,
          });
        },
        onLeaveBack: () => {
          // Resetear todo cuando se sale por arriba
          gsap.set("#flores-arriba-despedida", {
            opacity: 0,
            y: -30,
            scale: 0.8,
          });
          gsap.set("#card-despedida", { opacity: 0, y: 40, scale: 0.95 });
          gsap.set(".parrafo-animado", {
            opacity: 0,
            y: 30,
            filter: "blur(5px)",
          });
          gsap.set("#linea-decorativa", { opacity: 0, scale: 0.5 });
          gsap.set("#texto-confirmar", { opacity: 0, y: 20 });
          gsap.set("#boton-confirmar", { opacity: 0, scale: 0.8, y: 20 });
          gsap.set("#mensaje-final", { opacity: 0, scale: 0.9, y: 20 });
        },
      });

      console.log("💌✨ ¡Sección de despedida activada!");
    });
  }
</script>

<style>
  /* Efecto hover en el card */
  #card-despedida:hover {
    box-shadow: 0 20px 40px rgba(162, 119, 53, 0.15);
    transition: box-shadow 0.5s ease;
  }

  /* Resaltar palabras importantes */
  #mensaje-despedida span {
    transition: all 0.3s ease;
  }

  #mensaje-despedida span:hover {
    color: #c9a55e;
    text-shadow: 0 0 10px rgba(162, 119, 53, 0.3);
  }
</style>
